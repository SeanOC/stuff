[workspace]
provider = "claude"

[providers]
[providers.claude]
base = "builtin:claude"
ready_delay_ms = 0

# [mail]
# retention_ttl controls how long read messages are retained before purge.
# 0 disables retention; use "168h" for 7 days.
# "7d" is not a valid Go duration.
# retention_ttl = "0"

[[rigs]]
name = "stuff"
prefix = "pst"
default_branch = "main"

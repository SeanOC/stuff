
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# OpenSCAD workflow artifacts
# renders/*/ is tracked — regenerated in CI (.github/workflows/ci.yml `render` job)
# so Vercel deploys ship baseline thumbnails for the listing page.
exports/*.stl
libs/bin/*.AppImage

# Vendored OpenSCAD libraries (cloned; re-fetchable)
libs/NopSCADlib/
libs/threads-scad/
libs/MCAD/
libs/BOSL2/
libs/QuackWorks/
libs/gridfinity-rebuilt-openscad/

# Claude Code local state
.claude/scheduled_tasks.lock

# Local-only project context + multi-agent runbook commands.
# These reference internal tooling and are intentionally not shipped.
CLAUDE.local.md
.claude/commands/done.md
.claude/commands/handoff.md

# Python
__pycache__/
*.pyc

# Next.js / Node
node_modules/
.next/
.runtime/

# Next.js auto-generated; regenerated on every dev/build
next-env.d.ts
*.tsbuildinfo

# Playwright
playwright-report/
test-results/
playwright/.cache/
.vercel

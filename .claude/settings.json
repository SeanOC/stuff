{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(openscad:*)",
      "Bash(xvfb-run:*)",
      "Bash(python3 .claude/skills/_lib/*.py:*)",
      "Bash(python3 .claude/skills/*/scripts/*.py:*)",
      "Bash(python3 -m pytest .claude/skills/**:*)"
    ]
  }
}